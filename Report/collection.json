            {
              "listen": "test",
              "script": {
                "exec": [
                  "console.log('=== GET All Posts Test ===');",
                  "console.log('Status Code: ' + pm.response.code);",
                  "console.log('Response Time: ' + pm.response.responseTime + 'ms');",
                  "",
                  "pm.test('Status code is 200', function() {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Content-Type is application/json', function() {",
                  "    pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json');",
                  "});",
                  "",
                  "pm.test('Response time is within limits', function() {",
                  "    var maxTime = parseInt(pm.environment.get('max_response_time'));",
                  "    pm.expect(pm.response.responseTime).to.be.below(maxTime);",
                  "});",
                  "",
                  "var jsonData = pm.response.json();",
                  "pm.test('Response is an array', function() {",
                  "    pm.expect(jsonData).to.be.an('array');",
                  "});",
                  "",
                  "pm.test('Array has elements', function() {",
                  "    pm.expect(jsonData.length).to.be.above(0);",
                  "});",
                  "",
                  "pm.test('Each post has required fields', function() {",
                  "    jsonData.forEach(function(post) {",
                  "        pm.expect(post).to.have.property('userId');",
                  "        pm.expect(post).to.have.property('id');",
                  "        pm.expect(post).to.have.property('title');",
                  "        pm.expect(post).to.have.property('body');",
                  "    });",
                  "});",
                  "",
