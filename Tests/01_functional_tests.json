{
  "info": {
    "name": "01_Functional Tests",
    "description": "Basic API functionality tests",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "GET All Posts",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "console.log('=== GET All Posts Test ===');",
              "console.log('Status Code: ' + pm.response.code);",
              "console.log('Response Time: ' + pm.response.responseTime + 'ms');",
              "",
              "pm.test('Status code is 200', function() {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Content-Type is application/json', function() {",
              "    pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json');",
              "});",
              "",
              "pm.test('Response time is within limits', function() {",
              "    var maxTime = parseInt(pm.environment.get('max_response_time'));",
              "    pm.expect(pm.response.responseTime).to.be.below(maxTime);",
              "});",
              "",
              "var jsonData = pm.response.json();",
              "pm.test('Response is an array', function() {",
              "    pm.expect(jsonData).to.be.an('array');",
              "});",
              "",
              "pm.test('Array has elements', function() {",
              "    pm.expect(jsonData.length).to.be.above(0);",
              "});",
              "",
              "pm.test('Each post has required fields', function() {",
              "    jsonData.forEach(function(post) {",
              "        pm.expect(post).to.have.property('userId');",
              "        pm.expect(post).to.have.property('id');",
              "        pm.expect(post).to.have.property('title');",
              "        pm.expect(post).to.have.property('body');",
              "    });",
              "});",
              "",
              "console.log('Total posts: ' + jsonData.length);"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Content-Type",
            "value": "{{content_type}}",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{base_url}}/posts",
          "host": ["{{base_url}}"],
          "path": ["posts"]
        }
      }
    },
    {
      "name": "GET Single Post",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200', function() {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "var jsonData = pm.response.json();",
              "pm.test('Response is an object', function() {",
              "    pm.expect(jsonData).to.be.an('object');",
              "});",
              "",
              "pm.test('Post has all required fields', function() {",
              "    pm.expect(jsonData).to.have.property('userId');",
              "    pm.expect(jsonData).to.have.property('id');",
              "    pm.expect(jsonData).to.have.property('title');",
              "    pm.expect(jsonData).to.have.property('body');",
              "});",
              "",
              "pm.test('Post ID matches request parameter', function() {",
              "    var postId = parseInt(pm.environment.get('post_id'));",
              "    pm.expect(jsonData.id).to.equal(postId);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/posts/{{post_id}}",
          "host": ["{{base_url}}"],
          "path": ["posts", "{{post_id}}"]
        }
      }
    },
    {
      "name": "GET User Info",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200', function() {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "var jsonData = pm.response.json();",
              "pm.test('User has required fields', function() {",
              "    pm.expect(jsonData).to.have.property('id');",
              "    pm.expect(jsonData).to.have.property('name');",
              "    pm.expect(jsonData).to.have.property('email');",
              "});",
              "",
              "console.log('User: ' + jsonData.name);"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/users/{{user_id}}",
          "host": ["{{base_url}}"],
          "path": ["users", "{{user_id}}"]
        }
      }
    }
  ]
}
