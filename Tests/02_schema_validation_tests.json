{
  "info": {
    "name": "02_Schema Validation Tests",
    "description": "JSON Schema validation tests",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Validate Post Schema",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "console.log('=== Schema Validation Test ===');",
              "",
              "var jsonData = pm.response.json();",
              "",
              "pm.test('userId is number', function() {",
              "    pm.expect(jsonData.userId).to.be.a('number');",
              "});",
              "",
              "pm.test('id is number', function() {",
              "    pm.expect(jsonData.id).to.be.a('number');",
              "});",
              "",
              "pm.test('title is string', function() {",
              "    pm.expect(jsonData.title).to.be.a('string');",
              "    pm.expect(jsonData.title.length).to.be.above(0);",
              "});",
              "",
              "pm.test('body is string', function() {",
              "    pm.expect(jsonData.body).to.be.a('string');",
              "    pm.expect(jsonData.body.length).to.be.above(0);",
              "});",
              "",
              "pm.test('userId is positive', function() {",
              "    pm.expect(jsonData.userId).to.be.above(0);",
              "});",
              "",
              "pm.test('id is positive', function() {",
              "    pm.expect(jsonData.id).to.be.above(0);",
              "});",
              "",
              "console.log('Schema validation passed');"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/posts/1",
          "host": ["{{base_url}}"],
          "path": ["posts", "1"]
        }
      }
    }
  ]
}
