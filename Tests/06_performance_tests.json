{
  "info": {
    "name": "06_Performance Tests",
    "description": "API performance and response time tests",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Performance - GET Single Post",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "console.log('=== Performance Test: Single Post ===');",
              "console.log('Response Time: ' + pm.response.responseTime + 'ms');",
              "",
              "var maxTime = parseInt(pm.environment.get('max_response_time'));",
              "pm.environment.set('response_time', pm.response.responseTime);",
              "",
              "pm.test('Response time < ' + maxTime + 'ms', function() {",
              "    pm.expect(pm.response.responseTime).to.be.below(maxTime);",
              "});",
              "",
              "pm.test('Response time < 500ms (good performance)', function() {",
              "    pm.expect(pm.response.responseTime).to.be.below(500);",
              "});",
              "",
              "pm.test('Response time < 1000ms (acceptable)', function() {",
              "    pm.expect(pm.response.responseTime).to.be.below(1000);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/posts/1",
          "host": ["{{base_url}}"],
          "path": ["posts", "1"]
        }
      }
    },
    {
      "name": "Performance - GET All Posts",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "console.log('=== Performance Test: All Posts ===');",
              "console.log('Response Time: ' + pm.response.responseTime + 'ms');",
              "",
              "pm.test('Response time < 2000ms', function() {",
              "    pm.expect(pm.response.responseTime).to.be.below(2000);",
              "});",
              "",
              "var jsonData = pm.response.json();",
              "console.log('Retrieved ' + jsonData.length + ' posts in ' + pm.response.responseTime + 'ms');"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/posts",
          "host": ["{{base_url}}"],
          "path": ["posts"]
        }
      }
    }
  ]
}
